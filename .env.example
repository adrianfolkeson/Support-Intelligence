# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/support_intelligence

# Claude API
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Z.ai API (GLM-4.7)
# Get your API key from: https://open.bigmodel.cn/usercenter/apikeys
ZAI_API_KEY=your_zai_api_key

# External Support Ticket API (configure based on your provider)
SUPPORT_API_URL=https://api.example.com/tickets
SUPPORT_API_KEY=your_support_api_key

# Stripe
# Get your API keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_... # $249/mo price ID from Stripe dashboard

# Email (Resend)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=Support Intelligence <alerts@yourdomain.com>

# Server
PORT=3000
API_PORT=3001
NODE_ENV=development

# CORS
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Scheduler
ENABLE_SCHEDULER=true
SCHEDULER_TIMEOUT_MS=1800000  # 30 minutes
MAX_PARALLEL_ORGS=5  # Process up to 5 organizations in parallel
