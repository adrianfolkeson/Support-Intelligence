{
  "name": "support-intelligence",
  "version": "1.0.0",
  "description": "AI-powered support ticket analysis for SaaS founders",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "migrate": "node dist/database/migrate.js",
    "ingest": "node dist/services/ingestion.js",
    "analyze": "node dist/services/analysis.js",
    "report": "node dist/services/report-generator.js",
    "scheduler": "node dist/scheduler/index.js",
    "api": "node dist/api/server.js"
  },
  "keywords": ["support", "ai", "saas", "analytics"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
