{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "web/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    { "src": "/health", "dest": "api/index.ts" },
    { "src": "/api/organizations/(.*)", "dest": "api/index.ts" },
    { "src": "/api/reports/(.*)", "dest": "api/index.ts" },
    { "src": "/api/stripe/(.*)", "dest": "api/index.ts" },
    { "src": "/api/upload", "dest": "api/index.ts" },
    { "src": "/api/analyze", "dest": "api/index.ts" },
    { "src": "/(.*)", "dest": "web/$1" }
  ]
}
