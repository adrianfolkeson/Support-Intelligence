{
  "name": "support-intelligence",
  "version": "1.0.0",
  "description": "AI-powered support ticket analysis for SaaS founders",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "migrate": "node dist/database/migrate.js",
    "ingest": "node dist/services/ingestion.js",
    "analyze": "node dist/services/analysis.js",
    "analyze-router": "ts-node src/services/analysis-with-router.js",
    "report": "node dist/services/report-generator.js",
    "scheduler": "node dist/scheduler/index.js",
    "api": "node dist/api/server.js",
    "test-ai": "ts-node src/ai/test.ts",
    "test": "jest"
  },
  "keywords": [
    "support",
    "ai",
    "saas",
    "analytics"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@clerk/backend": "^2.30.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "node-cron": "^3.0.3",
    "papaparse": "^5.5.3",
    "pg": "^8.13.1",
    "stripe": "^14.14.0",
    "uuid": "^9.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^9.0.8",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
