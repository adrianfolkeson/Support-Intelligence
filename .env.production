# =============================================================================
# PRODUCTION ENVIRONMENT - Support Intelligence
# =============================================================================
# Copy this file to .env and fill in your production values
# DO NOT commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Docker)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/support_intelligence

# -----------------------------------------------------------------------------
# Claude API (Anthropic)
# -----------------------------------------------------------------------------
# Get your API key from: https://console.anthropic.com/settings/keys
# Add credits to your account for production use
ANTHROPIC_API_KEY=sk-ant-your-production-api-key

# -----------------------------------------------------------------------------
# Z.ai API (GLM-4.7) - Optional backup
# -----------------------------------------------------------------------------
ZAI_API_KEY=your_zai_api_key_if_using

# -----------------------------------------------------------------------------
# External Support Ticket API
# -----------------------------------------------------------------------------
# Configure this based on your support platform:
# - Zendesk: https://{subdomain}.zendesk.com/api/v2/tickets.json
# - Freshdesk: https://{domain}.freshdesk.com/api/v2/tickets
# - Intercom: https://api.intercom.io/conversations
SUPPORT_API_URL=https://your-support-platform.com/api/tickets
SUPPORT_API_KEY=your-support-platform-api-key

# -----------------------------------------------------------------------------
# Stripe (Payment Processing)
# -----------------------------------------------------------------------------
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID=price_your_stripe_price_id  # $249/mo price

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Support Intelligence <alerts@yourdomain.com>

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=3000
API_PORT=3001
NODE_ENV=production

# -----------------------------------------------------------------------------
# CORS (Comma-separated list of allowed origins)
# -----------------------------------------------------------------------------
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# -----------------------------------------------------------------------------
# Scheduler Configuration
# -----------------------------------------------------------------------------
ENABLE_SCHEDULER=true
SCHEDULER_TIMEOUT_MS=1800000  # 30 minutes per organization
MAX_PARALLEL_ORGS=5           # Process up to 5 organizations in parallel

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
