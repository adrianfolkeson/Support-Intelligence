# Database
# IMPORTANT: Use SSL mode require in production
DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require

# Claude API
# Get your API key from: https://console.anthropic.com/settings/keys
# IMPORTANT: Rotate this key immediately if exposed
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Z.ai API (GLM-4.7)
# Get your API key from: https://open.bigmodel.cn/usercenter/apikeys
ZAI_API_KEY=your_zai_api_key

# External Support Ticket API (configure based on your provider)
SUPPORT_API_URL=https://api.example.com/tickets
SUPPORT_API_KEY=your_support_api_key

# Stripe
# Get your API keys from: https://dashboard.stripe.com/apikeys
# IMPORTANT: Use test keys for development, live keys for production
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
STRIPE_PRICE_ID=price_YOUR_PRICE_ID

# Email (Resend)
# Get your API key from: https://resend.com/api-keys
# IMPORTANT: Verify your domain in Resend dashboard
RESEND_API_KEY=re_YOUR_API_KEY
EMAIL_FROM=Support Intelligence <alerts@yourdomain.com>

# Server
PORT=3000
API_PORT=3001
NODE_ENV=development

# CORS
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Scheduler
ENABLE_SCHEDULER=true
SCHEDULER_TIMEOUT_MS=1800000  # 30 minutes
MAX_PARALLEL_ORGS=5  # Process up to 5 organizations in parallel

# Redis (for distributed rate limiting)
REDIS_URL=redis://your-redis-instance.upstash.io

# Rate Limiting
RATE_LIMIT_PUBLIC=20
RATE_LIMIT_API=1000
RATE_LIMIT_WEBHOOK=100
RATE_LIMIT_WINDOW_SEC=60

# AI Settings
AI_MAX_RETRIES=3
AI_TIMEOUT_MS=30000
AI_BATCH_SIZE=10

# Database
DB_POOL_SIZE=10
DB_TIMEOUT_MS=5000

# Logging
LOG_LEVEL=info

# Aurora Integration
# Aurora API for churn prediction and customer intelligence
AURORA_API_URL=http://localhost:3000
AURORA_API_KEY=your_aurora_api_key_here
WEBHOOK_SECRET=your-webhook-secret-for-signatures
