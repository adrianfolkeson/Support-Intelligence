# Database
DATABASE_URL=postgresql://user:password@localhost:5432/support_intelligence

# Claude API
ANTHROPIC_API_KEY=your_claude_api_key_here

# External Support Ticket API (configure based on your provider)
SUPPORT_API_URL=https://api.example.com/tickets
SUPPORT_API_KEY=your_support_api_key

# Server
PORT=3000
NODE_ENV=development

# Scheduler
ENABLE_SCHEDULER=true
